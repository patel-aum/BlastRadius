{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datacontract-governance.io/schemas/contract-v3.1.0.json",
  "title": "Data Contract (ODCS v3.1.0 Subset)",
  "description": "JSON Schema for validating YAML data contracts based on the Open Data Contract Standard.",
  "type": "object",
  "required": ["kind", "apiVersion", "id", "domain", "dataProduct", "version", "status", "schema"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["DataContract"]
    },
    "apiVersion": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "dataProduct": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "retired", "draft"]
    },
    "description": {
      "type": "object",
      "properties": {
        "purpose": { "type": "string" },
        "limitations": { "type": "string" },
        "usage": { "type": "string" }
      }
    },
    "server": {
      "type": "object",
      "required": ["type", "database", "schema"],
      "properties": {
        "type": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "database": { "type": "string" },
        "schema": { "type": "string" }
      }
    },
    "schema": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "properties"],
        "properties": {
          "name": { "type": "string" },
          "physicalName": { "type": "string" },
          "physicalType": {
            "type": "string",
            "enum": ["table", "view", "materialized_view"]
          },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "properties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/definitions/columnProperty"
            }
          },
          "quality": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/qualityRule"
            }
          }
        }
      }
    },
    "slaProperties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["property", "value"],
        "properties": {
          "property": {
            "type": "string",
            "enum": ["latency", "frequency", "retention", "generalAvailability", "endOfSupport", "endOfLife", "timeOfAvailability"]
          },
          "value": {},
          "unit": { "type": "string" },
          "element": { "type": "string" },
          "driver": { "type": "string" }
        }
      }
    },
    "quality": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/qualityRule"
      }
    },
    "team": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["username", "role"],
            "properties": {
              "username": { "type": "string" },
              "role": { "type": "string" },
              "dateIn": { "type": "string", "format": "date" }
            }
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "access"],
        "properties": {
          "role": { "type": "string" },
          "access": { "type": "string", "enum": ["read", "write", "readwrite", "admin"] },
          "firstLevelApprovers": { "type": "string" },
          "secondLevelApprovers": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "customProperties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["property", "value"],
        "properties": {
          "property": { "type": "string" },
          "value": {}
        }
      }
    },
    "support": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": { "type": "string" },
          "tool": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "contractCreatedTs": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "columnProperty": {
      "type": "object",
      "required": ["name", "logicalType"],
      "properties": {
        "name": { "type": "string" },
        "physicalName": { "type": "string" },
        "logicalType": {
          "type": "string",
          "enum": ["string", "integer", "float", "double", "decimal", "boolean", "date", "timestamp", "binary", "array", "object", "long", "uuid"]
        },
        "physicalType": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "primaryKey": { "type": "boolean", "default": false },
        "partitioned": { "type": "boolean", "default": false },
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "examples": {
          "type": "array",
          "items": {}
        },
        "quality": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/qualityRule"
          }
        }
      }
    },
    "qualityRule": {
      "type": "object",
      "required": ["metric"],
      "properties": {
        "metric": { "type": "string" },
        "mustBe": {},
        "mustBeGreaterThan": { "type": "number" },
        "mustBeLessThan": { "type": "number" },
        "mustBeGreaterThanOrEqualTo": { "type": "number" },
        "mustBeLessThanOrEqualTo": { "type": "number" },
        "mustNotBe": {},
        "type": {
          "type": "string",
          "enum": ["library", "text", "sql", "custom"],
          "default": "library"
        },
        "description": { "type": "string" },
        "dimension": {
          "type": "string",
          "enum": ["completeness", "accuracy", "consistency", "timeliness", "uniqueness", "validity"]
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error"
        },
        "unit": { "type": "string" },
        "schedule": { "type": "string" },
        "scheduler": { "type": "string" }
      }
    }
  }
}
